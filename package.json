{
  "name": "@stompbox/spring-reverb",
  "version": "1.5.1",
  "keywords": ["handler", "use case", "usecase", "use-case", "domain driven", "ddd", "domain driven design", "next"],
  "description": "Framework-agnostic plug-and-play handlers with adapters.",
  "repository": {
    "type": "git",
    "url": "https://github.com/alevnyacow/stompbox-spring-reverb.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "check": "biome check --write",
    "dev": "rslib --watch",
    "format": "biome format --write",
    "test": "rstest",
    "test:watch": "rstest --watch"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@rslib/core": "^0.21.2",
    "@rstest/adapter-rslib": "^0.2.2",
    "@rstest/core": "^0.9.7",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^24.12.2",
    "next": "^16.2.4",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@stompbox/limiter": "^4.6.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "next": ">=13 <17"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  }
